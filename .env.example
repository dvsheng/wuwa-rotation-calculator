# PostgreSQL connection string
DATABASE_URL=postgres://localhost:5432/wuwa_rotation_builder
# Cognito — server-side JWT verification (Lambda env vars)
COGNITO_USER_POOL_ID=YOUR_USER_POOL_ID
COGNITO_USER_POOL_CLIENT_ID=YOUR_USER_POOL_CLIENT_ID
# Cognito — client-side Amplify config (Vite build-time)
VITE_COGNITO_USER_POOL_ID=YOUR_USER_POOL_ID
VITE_COGNITO_USER_POOL_CLIENT_ID=YOUR_USER_POOL_CLIENT_ID
VITE_COGNITO_REGION=us-east-1
# Cognito Hosted UI domain (from CDK output HostedUiDomain — strip https:// prefix)
VITE_COGNITO_DOMAIN=YOUR_COGNITO_DOMAIN.auth.us-east-1.amazoncognito.com
# App URL used as OAuth redirect (defaults to http://localhost:3000/ if unset)
VITE_APP_URL=http://localhost:3000/
